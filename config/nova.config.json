{
  "nova": {
    "version": "0.1.0",
    "name": "Nova",
    "description": "Asistente Virtual de IA Personal",
    "core": {
      "modelProvider": "openai",
      "defaultModel": "gpt-4",
      "temperature": 0.7,
      "maxTokens": 1000
    },
    "gateway": {
      "port": 18789,
      "host": "localhost",
      "enableWebsocket": true,
      "enableRestAPI": true
    },
    "channels": {
      "enabled": ["cli"],
      "available": ["cli", "web", "telegram", "whatsapp"]
    },
    "plugins": {
      "pluginDir": "./plugins",
      "enabled": [],
      "sandboxEnabled": true
    },
    "memory": {
      "provider": "local",
      "persistence": true,
      "storagePath": "./data/memory"
    },
    "logging": {
      "level": "info",
      "file": "./logs/nova.log",
      "maxSize": "10m",
      "maxFiles": 5
    }
  },
  "development": {
    "watchMode": true,
    "autoReload": true,
    "debug": true
  }
}